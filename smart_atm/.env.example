# ============================================
#  Smart ATM Assistant — Environment Config
# ============================================

# Telegram
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=AAB_Support_Bot

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/smart_atm

# Redis (FSM storage)
REDIS_URL=redis://localhost:6379/0

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_key

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your_secret_key_here

# Admin panel JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE_HOURS=24

# Webhook (production)
WEBHOOK_URL=https://yourdomain.com/webhook
WEBHOOK_PATH=/webhook
